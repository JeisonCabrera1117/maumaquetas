{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "maumaquetas.com" }],
      "destination": "https://www.maumaquetas.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "maumaquetas.vercel.app" }],
      "destination": "https://www.maumaquetas.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
